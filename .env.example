# Google Maps API Key
# Enable: Maps JavaScript API, Directions API, Places API, Geocoding API
# Get it at: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=

# Proxy base URL
# Development: leave as default (uses Vite dev proxy)
# Production: set to your Cloudflare Worker URL, e.g. https://api.yourdomain.com
VITE_PROXY_BASE_URL=http://localhost:5173/proxy

# GTFS URLs (derived from PROXY_BASE_URL by default — only override if needed)
# VITE_GTFS_STATIC_URL=/proxy/mot/gtfs/israel-public-transportation.zip
# VITE_GTFS_RT_VEHICLE_URL=/proxy/mot/gtfsrealtime/VehiclePosition
# VITE_GTFS_RT_TRIP_URL=/proxy/mot/gtfsrealtime/TripUpdate
# VITE_GTFS_RT_ALERT_URL=/proxy/mot/gtfsrealtime/ServiceAlert
